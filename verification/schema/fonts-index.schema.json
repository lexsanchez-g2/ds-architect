{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lsanchez-g2/ds-architect/verification/schema/fonts-index.schema.json",
  "title": "BUNDLE data/fonts/_index.json",
  "description": "Per BUNDLE_SPEC.md §7.3. If selfHosted, files in assets/fonts/*.woff2 with per-weight manifest.",
  "type": "object",
  "required": ["fonts"],
  "additionalProperties": true,
  "properties": {
    "fonts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["family", "weights", "selfHosted"],
        "properties": {
          "family": { "type": "string", "minLength": 1 },
          "weights": {
            "type": "array",
            "items": { "type": "integer", "minimum": 100, "maximum": 1000 },
            "uniqueItems": true
          },
          "styles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "selfHosted": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  }
}
