{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lsanchez-g2/ds-architect/verification/schema/pixel-diff.schema.json",
  "title": "BUNDLE verification/pixel-diff.json",
  "description": "Per BUNDLE_SPEC.md §10.2. Generated by reverse-render verifier. Thresholds §10.4: SSIM mean >= 0.97; SSIM min >= 0.85 (per-variant investigation required).",
  "type": "object",
  "required": ["tool", "renderedAt", "components"],
  "additionalProperties": true,
  "properties": {
    "tool": { "type": "string" },
    "renderedAt": { "type": "string", "format": "date-time" },
    "components": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "properties": {
            "variantsTested": { "type": "integer", "minimum": 0 },
            "variantsPassed": { "type": "integer", "minimum": 0 },
            "pixelFidelity": { "type": "number", "minimum": 0, "maximum": 1 },
            "ssimMean": { "type": "number", "minimum": 0, "maximum": 1 },
            "ssimMin": { "type": "number", "minimum": 0, "maximum": 1 },
            "ssimMax": { "type": "number", "minimum": 0, "maximum": 1 },
            "ssimStdDev": { "type": "number", "minimum": 0 },
            "failures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["variantKey"],
                "properties": {
                  "variantKey": { "type": "string" },
                  "ssim": { "type": "number", "minimum": 0, "maximum": 1 },
                  "reason": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  }
}
