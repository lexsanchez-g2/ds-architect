{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lsanchez-g2/ds-architect/verification/schema/variants.schema.json",
  "title": "BUNDLE data/components/<Component>.variants.json",
  "description": "Per BUNDLE_SPEC.md §6.3 / §6.4 / §6.5. Every variant cell as a full recursive node tree. Heart of fidelity — skipping cells = drift. Per §6.5 default-equal fields MAY be omitted (rotation:0, opacity:1, visible:true, empty strokes); consumers treat missing as default. Omission set documented in MANIFEST.extensions.omittedDefaults.",
  "$defs": {
    "bindingStatus": {
      "enum": ["fully-bound", "partial", "hardcoded", "semantically-mismatched"]
    },
    "geometry": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "rotation": { "type": "number" },
        "constraints": {
          "type": "object",
          "properties": {
            "horizontal": { "type": "string", "enum": ["MIN", "MAX", "CENTER", "STRETCH", "SCALE"] },
            "vertical": { "type": "string", "enum": ["MIN", "MAX", "CENTER", "STRETCH", "SCALE"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "layout": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["NONE", "HORIZONTAL", "VERTICAL"] },
        "paddingTop": { "type": "number" },
        "paddingRight": { "type": "number" },
        "paddingBottom": { "type": "number" },
        "paddingLeft": { "type": "number" },
        "itemSpacing": { "type": "number" },
        "primaryAxisAlignItems": { "type": "string", "enum": ["MIN", "CENTER", "MAX", "SPACE_BETWEEN"] },
        "counterAxisAlignItems": { "type": "string", "enum": ["MIN", "CENTER", "MAX", "BASELINE"] },
        "primaryAxisSizingMode": { "type": "string", "enum": ["AUTO", "FIXED"] },
        "counterAxisSizingMode": { "type": "string", "enum": ["AUTO", "FIXED"] },
        "layoutWrap": { "type": "string", "enum": ["NO_WRAP", "WRAP"] },
        "bindings": { "type": "object", "additionalProperties": { "type": ["string", "null"] } }
      },
      "additionalProperties": true
    },
    "fill": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["SOLID", "GRADIENT_LINEAR", "GRADIENT_RADIAL", "GRADIENT_ANGULAR", "GRADIENT_DIAMOND", "IMAGE", "VIDEO", "EMOJI"] },
        "color": { "type": "string" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "blendMode": { "type": "string" },
        "boundVariable": { "type": ["string", "object", "null"] },
        "visible": { "type": "boolean" },
        "imageRef": { "type": "string" },
        "gradientStops": { "type": "array" },
        "gradientTransform": { "type": "array" },
        "scaleMode": { "type": "string", "enum": ["FILL", "FIT", "CROP", "TILE"] }
      },
      "additionalProperties": true
    },
    "stroke": { "$ref": "#/$defs/fill" },
    "effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["INNER_SHADOW", "DROP_SHADOW", "LAYER_BLUR", "BACKGROUND_BLUR"] },
        "offset": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": true
        },
        "radius": { "type": "number" },
        "spread": { "type": "number" },
        "color": { "type": "string" },
        "blendMode": { "type": "string" },
        "visible": { "type": "boolean" },
        "boundVariable": { "type": ["string", "object", "null"] }
      },
      "additionalProperties": true
    },
    "cornerRadius": {
      "type": "object",
      "properties": {
        "topLeft": { "type": "number", "minimum": 0 },
        "topRight": { "type": "number", "minimum": 0 },
        "bottomLeft": { "type": "number", "minimum": 0 },
        "bottomRight": { "type": "number", "minimum": 0 },
        "smoothing": { "type": "number", "minimum": 0, "maximum": 1 },
        "boundVariable": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "topLeft": { "type": ["string", "null"] },
                "topRight": { "type": ["string", "null"] },
                "bottomLeft": { "type": ["string", "null"] },
                "bottomRight": { "type": ["string", "null"] }
              },
              "additionalProperties": true
            }
          ]
        },
        "$bindingStatus": { "$ref": "#/$defs/bindingStatus" },
        "$bindingMismatchNote": { "type": "string" }
      },
      "additionalProperties": true
    },
    "instanceOverride": {
      "type": "object",
      "required": ["propertyName"],
      "properties": {
        "propertyName": { "type": "string" },
        "value": {},
        "overriddenAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "instanceMain": {
      "type": "object",
      "properties": {
        "figmaKey": { "type": "string" },
        "libraryKey": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "FRAME", "COMPONENT", "COMPONENT_SET", "INSTANCE",
            "TEXT", "RECTANGLE", "ELLIPSE", "VECTOR",
            "BOOLEAN_OPERATION", "GROUP", "LINE", "STAR", "POLYGON", "SLICE"
          ]
        },
        "name": { "type": "string" },
        "figmaNodeId": { "type": "string" },
        "geometry": { "$ref": "#/$defs/geometry" },
        "visible": { "type": "boolean" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "blendMode": { "type": "string" },
        "fills": { "type": "array", "items": { "$ref": "#/$defs/fill" } },
        "strokes": { "type": "array", "items": { "$ref": "#/$defs/stroke" } },
        "strokeWeight": { "type": "number", "minimum": 0 },
        "strokeAlign": { "type": "string", "enum": ["INSIDE", "OUTSIDE", "CENTER"] },
        "strokeDashes": { "type": "array", "items": { "type": "number" } },
        "strokeCap": { "type": "string" },
        "strokeJoin": { "type": "string" },
        "strokeMiterLimit": { "type": "number" },
        "effects": { "type": "array", "items": { "$ref": "#/$defs/effect" } },
        "cornerRadius": { "$ref": "#/$defs/cornerRadius" },
        "layout": { "$ref": "#/$defs/layout" },
        "clipsContent": { "type": "boolean" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "$bindingStatus": { "$ref": "#/$defs/bindingStatus" },
        "$bindingMismatchNote": { "type": "string" },

        "characters": { "type": "string" },
        "font": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "style": { "type": "string" },
            "weight": { "type": "number" },
            "size": { "type": "number" }
          },
          "additionalProperties": true
        },
        "lineHeight": {
          "type": "object",
          "properties": {
            "unit": { "type": "string", "enum": ["PIXELS", "PERCENT", "AUTO"] },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        },
        "letterSpacing": {
          "type": "object",
          "properties": {
            "unit": { "type": "string", "enum": ["PIXELS", "PERCENT"] },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        },
        "paragraphSpacing": { "type": "number" },
        "paragraphIndent": { "type": "number" },
        "textAlignHorizontal": { "type": "string", "enum": ["LEFT", "CENTER", "RIGHT", "JUSTIFIED"] },
        "textAlignVertical": { "type": "string", "enum": ["TOP", "CENTER", "BOTTOM"] },
        "textCase": { "type": "string", "enum": ["ORIGINAL", "UPPER", "LOWER", "TITLE", "SMALL_CAPS", "SMALL_CAPS_FORCED"] },
        "textDecoration": { "type": "string", "enum": ["NONE", "UNDERLINE", "STRIKETHROUGH"] },
        "textAutoResize": { "type": "string", "enum": ["NONE", "WIDTH_AND_HEIGHT", "HEIGHT", "TRUNCATE"] },
        "boundTextStyle": { "type": ["string", "null"] },
        "textRangeOverrides": { "type": "array" },
        "fontVariations": { "type": "object" },
        "listOptions": { "type": "object" },
        "hyperlink": { "type": "object" },
        "openTypeFeatures": { "type": "object" },
        "textStyleId": { "type": "string" },

        "mainComponent": { "$ref": "#/$defs/instanceMain" },
        "overrides": { "type": "array", "items": { "$ref": "#/$defs/instanceOverride" } },

        "vectorPaths": { "type": "array" },
        "vectorNetwork": { "type": "object" },
        "exportedSvg": { "type": "string", "pattern": "\\.svg$" }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["componentId", "variants"],
  "additionalProperties": true,
  "properties": {
    "componentId": { "type": "string", "minLength": 1 },
    "variantCount": { "type": "integer", "minimum": 0 },
    "variantsEmittedCount": { "type": "integer", "minimum": 0 },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "node"],
        "properties": {
          "key": { "type": "string", "pattern": "^[A-Za-z0-9_-]+=[^,]+(,[A-Za-z0-9_-]+=[^,]+)*$" },
          "figmaNodeId": { "type": "string" },
          "node": { "$ref": "#/$defs/node" }
        },
        "additionalProperties": true
      }
    }
  }
}
