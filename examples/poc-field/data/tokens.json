{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "Field (node 18684:15220) + nested InputGroup + KbdGroup + Kbd" },
    "modes": ["light"],
    "overlapWithPriorBundles": {
      "$comment": "25 tokens, mostly carry from Input + Button bundles via nested-instance composition. Field is the deepest PoC (5+ levels), so its token surface = union of all nested components' tokens. SP-8 case at depth."
    }
  },

  "color": {
    "base": {
      "foreground":       { "$value": "#0a0a0a", "$type": "color", "$description": "Label text in Default state.",  "$extensions": { "figma": { "name": "base/foreground" } } },
      "muted-foreground": { "$value": "#737373", "$type": "color", "$description": "Description + Kbd text.",         "$extensions": { "figma": { "name": "base/muted-foreground" } } },
      "muted":            { "$value": "#f5f5f5", "$type": "color", "$description": "Kbd chip fill.",                 "$extensions": { "figma": { "name": "base/muted" } } },
      "destructive":      { "$value": "#dc2626", "$type": "color", "$description": "Label color in Invalid state.",  "$extensions": { "figma": { "name": "base/destructive" } } },
      "input":            { "$value": "#a3a3a3", "$type": "color", "$description": "InputGroup border (inherited).", "$extensions": { "figma": { "name": "base/input" } } }
    },
    "custom": {
      "background-dark-input-30": { "$value": "#fafafa", "$type": "color", "$description": "InputGroup fill (inherited).", "$extensions": { "figma": { "name": "custom/background dark:input\\30" } } }
    }
  },

  "spacing": {
    "1":   { "$value": "4px",  "$type": "dimension", "$description": "Kbd internal gap + Kbd horizontal padding.", "$extensions": { "figma": { "name": "spacing/1" } } },
    "1-5": { "$value": "6px",  "$type": "dimension", "$description": "InputGroup gap (inherited).",                "$extensions": { "figma": { "name": "spacing/1-5" } } },
    "2":   { "$value": "8px",  "$type": "dimension", "$description": "Field container gap (label/input/description).", "$extensions": { "figma": { "name": "spacing/2" } } },
    "2-5": { "$value": "10px", "$type": "dimension", "$description": "InputGroup horizontal padding (inherited).",  "$extensions": { "figma": { "name": "spacing/2-5" } } }
  },

  "height": {
    "h-5":  { "$value": "20px", "$type": "dimension", "$description": "Kbd height.",     "$extensions": { "figma": { "name": "height/h-5" } } },
    "h-11": { "$value": "44px", "$type": "dimension", "$description": "InputGroup height (inherited from Input atom).", "$extensions": { "figma": { "name": "height/h-11" } } }
  },

  "width": {
    "w-5": { "$value": "20px", "$type": "dimension", "$description": "Kbd min-width.", "$extensions": { "figma": { "name": "width/w-5" } } }
  },

  "border-radius": {
    "rounded-sm": { "$value": "6px",  "$type": "dimension", "$description": "Kbd chip corner radius.",         "$extensions": { "figma": { "name": "border-radius/rounded-sm" } } },
    "rounded-lg": { "$value": "10px", "$type": "dimension", "$description": "InputGroup container (inherited).", "$extensions": { "figma": { "name": "border-radius/rounded-lg" } } }
  },

  "border-width": {
    "border": { "$value": "1px", "$type": "dimension", "$extensions": { "figma": { "name": "border-width/border" } } }
  },

  "font": {
    "font-sans": { "$value": "Open Sans", "$type": "fontFamily", "$extensions": { "figma": { "name": "font/font-sans" } } }
  },

  "font-weight": {
    "medium": { "$value": 500, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/medium" } } },
    "normal": { "$value": 400, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/normal" } } }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    },
    "xs": {
      "font-size":   { "$value": "12px", "$type": "dimension", "$extensions": { "figma": { "name": "text/xs/font-size" } } },
      "line-height": { "$value": "16px", "$type": "dimension", "$extensions": { "figma": { "name": "text/xs/line-height" } } }
    }
  },

  "typography": {
    "text-sm-leading-normal-medium": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.medium}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Label typography (Field-level).",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/medium" } }
    },
    "text-sm-leading-normal-normal": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Description + Link typography.",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/normal" } }
    },
    "text-xs-leading-normal-medium": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.medium}", "fontSize": "{text.xs.font-size}", "lineHeight": "{text.xs.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Kbd glyph text — xs scale + medium weight. NEW in Field bundle vs prior bundles (Avatar had xs-normal, Switch had sm-leading-none-medium).",
      "$extensions": { "figma": { "name": "text-xs/leading-normal/medium" } }
    }
  },

  "icon-set": {
    "lucide-icons": { "$value": true, "$type": "boolean", "$extensions": { "figma": { "name": "Lucide Icons" } } }
  }
}
