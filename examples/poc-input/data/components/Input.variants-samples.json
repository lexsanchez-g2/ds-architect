      "node": {
        "type": "COMPONENT",
        "name": "Variant=Default, State=Invalid",
        "figmaNodeId": "17428:7308",
        "elementHint": "<input type='text' aria-invalid='true'>",
        "geometry": { "width": 373, "height": 44, "$widthBindingStatus": "hardcoded" },
        "layout": {
          "mode": "HORIZONTAL",
          "paddingTop": 4, "paddingRight": 10, "paddingBottom": 4, "paddingLeft": 10,
          "itemSpacing": 4,
          "bindings": { "paddingTop": "{spacing.1}", "paddingRight": "{spacing.2-5}", "paddingBottom": "{spacing.1}", "paddingLeft": "{spacing.2-5}", "itemSpacing": "{spacing.1}", "height": "{height.h-11}" }
