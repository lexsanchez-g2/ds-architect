{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": {
      "fileKey": "3401ZFUHoboOwA6GGjAEsq",
      "fileName": "Apollo v2 (SA) - Design System",
      "scope": "Input-subtree (node 65:533) — 24 tokens, only 2 NEW vs Button+Switch combined",
      "extractedAt": "2026-05-18T00:00:00Z",
      "extractor": "ds-architect@v3+input-poc"
    },
    "modes": ["light"],
    "overlapWithPriorBundles": {
      "sharedWithButton": 18,
      "sharedWithSwitch": 22,
      "uniqueToInput":    2,
      "$comment": "Input is the SMALLEST token delta of the atom batch. Only 2 net-new tokens vs Button+Switch combined: base/input (#a3a3a3) for the default input border color; custom/input-50-dark-input-80 (#e5e5e580) for the @50% alpha variant (likely Disabled or Filled state). Token consolidation to shared apollo-v2-tokens.json becomes more obviously worthwhile with each atom."
    }
  },

  "color": {
    "base": {
      "background":       { "$value": "#fafafa", "$type": "color", "$description": "Page background / Input fill in light mode.", "$extensions": { "shadcn": "background", "figma": { "name": "base/background" } } },
      "foreground":       { "$value": "#0a0a0a", "$type": "color", "$description": "Primary foreground text — Input typed text + Label.", "$extensions": { "shadcn": "foreground", "figma": { "name": "base/foreground" } } },
      "muted-foreground": { "$value": "#737373", "$type": "color", "$description": "Muted text — Input placeholder + helper.", "$extensions": { "shadcn": "muted-foreground", "figma": { "name": "base/muted-foreground" } } },
      "destructive":      { "$value": "#dc2626", "$type": "color", "$description": "Destructive — Input Invalid state border + ring tint base.", "$extensions": { "shadcn": "destructive", "figma": { "name": "base/destructive" } } },
      "ring":             { "$value": "#5a35c0", "$type": "color", "$description": "Focus ring base — Input Focus state border.", "$extensions": { "shadcn": "ring", "figma": { "name": "base/ring" } } },

      "input": {
        "$value": "#a3a3a3",
        "$type": "color",
        "$description": "Input default border color. Specifically named for input/text-field borders. Same hex as Switch's custom/input-dark-input-80 (track Off color) — Apollo v2 reuses the gray, distinct semantic.",
        "$extensions": { "intent": "input-border", "shadcn": "input", "tailwind": "border-input", "figma": { "name": "base/input" }, "sourceTrace": "NEW in Input PoC. First atom to use base/input as a top-level semantic color (Switch used custom/input-dark-input-80 with same hex value but as a track-fill semantic)." }
      }
    },

    "custom": {
      "outline": {
        "$value": "#a3a3a380", "$type": "color",
        "$description": "Focus ring color (neutral-gray with 50% alpha).",
        "$extensions": { "figma": { "name": "custom/outline" } }
      },
      "destructive-20-dark-40": {
        "$value": "#dc262633", "$type": "color",
        "$description": "Destructive @ 20% alpha (dark: 40%). Input Invalid focus ring spread color.",
        "$extensions": { "figma": { "name": "custom/destructive\\20 dark:destructive\\40" } }
      },
      "background-dark-input-30": {
        "$value": "#fafafa", "$type": "color",
        "$description": "Background neutral (dark: input @ 30%). Used as Input background fill.",
        "$extensions": { "figma": { "name": "custom/background dark:input\\30" } }
      },
      "input-50-dark-input-80": {
        "$value": "#e5e5e580",
        "$type": "color",
        "$description": "Input border @ 50% alpha (dark: 80%). Likely used on Disabled or non-default states to communicate diminished prominence.",
        "$extensions": {
          "intent": "input-border-alpha",
          "alpha": 0.50,
          "figma": { "name": "custom/input\\50 dark:input\\80" },
          "sourceTrace": "NEW in Input PoC. Used by Input at non-Default states. Confirm exact usage via Step 3 cell walks."
        }
      }
    }
  },

  "spacing": {
    "1":   { "$value": "4px",  "$type": "dimension", "$extensions": { "tailwind": "p-1",   "figma": { "name": "spacing/1" } } },
    "2-5": { "$value": "10px", "$type": "dimension", "$description": "10px spacing — Input internal padding.", "$extensions": { "tailwind": "p-2.5", "figma": { "name": "spacing/2-5" } } }
  },

  "height": {
    "h-11": { "$value": "44px", "$type": "dimension", "$description": "44px height — Input universal height (WCAG 2.5.5 compliant across all 15 cells).", "$extensions": { "tailwind": "h-11", "figma": { "name": "height/h-11" } } }
  },

  "border-radius": {
    "rounded-lg": { "$value": "10px", "$type": "dimension", "$description": "Large rounded corner — Input container.", "$extensions": { "tailwind": "rounded-lg", "figma": { "name": "border-radius/rounded-lg" } } }
  },

  "border-width": {
    "border": { "$value": "1px", "$type": "dimension", "$description": "Default border weight — Input border.", "$extensions": { "tailwind": "border", "figma": { "name": "border-width/border" } } }
  },

  "opacity": {
    "opacity-50": {
      "$value": 0.5, "$type": "number",
      "$description": "50% opacity — Input Disabled state visual cue (consistent with Switch Disabled pattern).",
      "$extensions": { "tailwind": "opacity-50", "figma": { "name": "opacity/opacity-50", "rawValue": "50" } }
    }
  },

  "font": {
    "font-sans": { "$value": "Open Sans", "$type": "fontFamily", "$extensions": { "tailwind": "font-sans", "figma": { "name": "font/font-sans" } } }
  },

  "font-weight": {
    "normal":   { "$value": 400, "$type": "fontWeight", "$description": "Normal weight — Input text + placeholder.",   "$extensions": { "tailwind": "font-normal", "figma": { "name": "font-weight/normal" } } },
    "medium":   { "$value": 500, "$type": "fontWeight", "$description": "Medium weight — Input Filled-state text (likely).", "$extensions": { "tailwind": "font-medium", "figma": { "name": "font-weight/medium" } } }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension", "$extensions": { "tailwind": "text-sm", "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    }
  },

  "typography": {
    "text-sm-leading-normal-normal": {
      "$value": {
        "fontFamily":   "{font.font-sans}",
        "fontWeight":   "{font-weight.normal}",
        "fontSize":     "{text.sm.font-size}",
        "lineHeight":   "{text.sm.line-height}",
        "letterSpacing": "0px"
      },
      "$type": "typography",
      "$description": "Body sm normal — Input placeholder / unfilled text.",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/normal" } }
    },
    "text-sm-leading-normal-medium": {
      "$value": {
        "fontFamily":   "{font.font-sans}",
        "fontWeight":   "{font-weight.medium}",
        "fontSize":     "{text.sm.font-size}",
        "lineHeight":   "{text.sm.line-height}",
        "letterSpacing": "0px"
      },
      "$type": "typography",
      "$description": "Body sm medium — Input Filled state (typed text).",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/medium" } }
    }
  },

  "effect": {
    "focus-default": {
      "$value": {
        "color":   "{color.custom.outline}",
        "offsetX": "0px", "offsetY": "0px",
        "blur":    "0px", "spread":  "3px",
        "type":    "dropShadow", "inset":  false
      },
      "$type": "shadow",
      "$description": "Focus ring — Input Focus state outer drop-shadow.",
      "$extensions": { "figma": { "name": "focus/default" } }
    },
    "focus-destructive": {
      "$value": {
        "color":   "{color.custom.destructive-20-dark-40}",
        "offsetX": "0px", "offsetY": "0px",
        "blur":    "0px", "spread":  "3px",
        "type":    "dropShadow", "inset":  false
      },
      "$type": "shadow",
      "$description": "Focus ring — Input Invalid state outer drop-shadow tinted destructive.",
      "$extensions": { "figma": { "name": "focus/destructive" } }
    }
  }
}
