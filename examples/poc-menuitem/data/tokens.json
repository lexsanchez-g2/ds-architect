{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "MenubarItem (419:6748)" },
    "modes": ["light"],
    "$note": "20 tokens. 1 NEW: spacing/7 (28px) — Level=2 left-indent for Radio/Checkbox variants. Rest carry from Sonner + Item + Tabs bundles."
  },

  "color": {
    "base": {
      "popover-foreground": { "$value": "#171717", "$type": "color", "$description": "Default menu-item text. Inherited from Sonner popover surface system." },
      "muted-foreground":   { "$value": "#737373", "$type": "color", "$description": "Shortcut text + Disabled menu-item text" },
      "destructive":        { "$value": "#dc2626", "$type": "color", "$description": "Destructive variant text" },
      "accent":             { "$value": "#ede9fe", "$type": "color", "$description": "Hover background (likely)" },
      "accent-foreground":  { "$value": "#5a35c0", "$type": "color", "$description": "Hover text (likely)" }
    },
    "custom": {
      "destructive-10-dark-20": { "$value": "#dc26261a", "$type": "color", "$description": "Destructive Hover bg @ 10% alpha (likely)" }
    }
  },

  "spacing": {
    "1":   { "$value": "4px",  "$type": "dimension", "$description": "padding-y" },
    "1-5": { "$value": "6px",  "$type": "dimension", "$description": "padding-x + gap" },
    "7":   { "$value": "28px", "$type": "dimension", "$description": "Level=2 Radio/Checkbox left-indent. NEW in MenuItem PoC.", "$extensions": { "tailwind": "p-7", "figma": { "name": "spacing/7" }, "sourceTrace": "NEW." } },
    "8":   { "$value": "32px", "$type": "dimension" }
  },

  "border-radius": {
    "rounded-md": { "$value": "8px", "$type": "dimension", "$description": "MenubarItem row radius (hover background follows this)" }
  },

  "opacity": {
    "opacity-50": { "$value": 0.5, "$type": "number", "$description": "Disabled state opacity" }
  },

  "font":        { "font-sans": { "$value": "Open Sans", "$type": "fontFamily" } },
  "font-weight": { "normal":    { "$value": 400, "$type": "fontWeight" } },

  "text": {
    "sm": { "font-size": { "$value": "14px", "$type": "dimension" }, "line-height": { "$value": "20px", "$type": "dimension" } },
    "xs": { "font-size": { "$value": "12px", "$type": "dimension" }, "line-height": { "$value": "16px", "$type": "dimension" } }
  },

  "typography": {
    "text-sm-leading-normal-normal": { "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" }, "$type": "typography", "$description": "Menu item label" },
    "text-xs-leading-normal-normal": { "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.xs.font-size}", "lineHeight": "{text.xs.line-height}", "letterSpacing": "0px" }, "$type": "typography", "$description": "Shortcut text" }
  },

  "icon-set": { "lucide-icons": { "$value": true, "$type": "boolean" } }
}
