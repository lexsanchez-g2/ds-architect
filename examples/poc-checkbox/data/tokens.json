{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "Checkbox (node 46:112)" },
    "modes": ["light"],
    "overlapWithPriorBundles": {
      "sharedWithButton+Switch+Input": 26,
      "uniqueToCheckbox": 4,
      "$comment": "30 tokens used. 4 NEW: border-radius/rounded-md (8px) — first atom to use medium radius; tailwind colors/base/white (#ffffff) — checkmark glyph fill; opacity/opacity-70 (70%) — usage TBD; opacity/opacity-60 (60%) — Pressed state."
    }
  },

  "color": {
    "base": {
      "primary":            { "$value": "#5a35c0", "$type": "color", "$extensions": { "figma": { "name": "base/primary" } } },
      "primary-foreground": { "$value": "#ffffff", "$type": "color", "$extensions": { "figma": { "name": "base/primary-foreground" } } },
      "foreground":         { "$value": "#0a0a0a", "$type": "color", "$extensions": { "figma": { "name": "base/foreground" } } },
      "muted-foreground":   { "$value": "#737373", "$type": "color", "$extensions": { "figma": { "name": "base/muted-foreground" } } },
      "destructive":        { "$value": "#dc2626", "$type": "color", "$extensions": { "figma": { "name": "base/destructive" } } },
      "input":              { "$value": "#a3a3a3", "$type": "color", "$description": "Default checkbox border color (when Checked=No)." },
      "border":             { "$value": "#e5e5e5", "$type": "color", "$extensions": { "figma": { "name": "base/border" } } },
      "ring":               { "$value": "#5a35c0", "$type": "color", "$extensions": { "figma": { "name": "base/ring" } } }
    },
    "custom": {
      "outline":                                { "$value": "#a3a3a380", "$type": "color", "$extensions": { "figma": { "name": "custom/outline" } } },
      "destructive-10-dark-20":                 { "$value": "#dc26261a", "$type": "color", "$extensions": { "figma": { "name": "custom/destructive\\10 dark:destructive\\20" } } },
      "background-dark-input-30":               { "$value": "#fafafa", "$type": "color", "$description": "Background neutral. Checkbox box fill when Checked=No." },
      "bg-primary-5-dark-bg-primary-10":        { "$value": "#1717170d", "$type": "color", "$extensions": { "figma": { "name": "custom/bg-primary\\5 dark:bg-primary\\10" } } },
      "alpha-30-dark-alpha-20":                 { "$value": "#ffffffb2", "$type": "color", "$extensions": { "figma": { "name": "custom/alpha-30 dark:alpha-20" } } }
    },
    "tailwind": {
      "base": {
        "white": {
          "$value": "#ffffff", "$type": "color",
          "$description": "Pure white. Checkmark glyph stroke color on Checked=Yes (via currentColor inherited from primary-foreground).",
          "$extensions": { "tailwind": "white", "figma": { "name": "tailwind colors/base/white" }, "sourceTrace": "NEW in Checkbox PoC." }
        }
      }
    }
  },

  "spacing": {
    "1-5": { "$value": "6px",  "$type": "dimension", "$description": "Label-to-description gap inside Field Content.", "$extensions": { "tailwind": "p-1.5", "figma": { "name": "spacing/1-5" } } },
    "2":   { "$value": "8px",  "$type": "dimension", "$description": "Checkbox-to-Field-Content gap.", "$extensions": { "tailwind": "p-2", "figma": { "name": "spacing/2" } } },
    "2-5": { "$value": "10px", "$type": "dimension", "$extensions": { "tailwind": "p-2.5", "figma": { "name": "spacing/2-5" } } }
  },

  "border-radius": {
    "rounded-md": {
      "$value": "8px", "$type": "dimension",
      "$description": "Medium rounded corner — NOT used by Checkbox box (which uses raw 4px); reserved for Box-type frames.",
      "$extensions": { "tailwind": "rounded-md", "figma": { "name": "border-radius/rounded-md" }, "sourceTrace": "NEW in Checkbox PoC vs Button+Switch+Input bundles." }
    }
  },

  "border-width": {
    "border": { "$value": "1px", "$type": "dimension", "$extensions": { "tailwind": "border", "figma": { "name": "border-width/border" } } }
  },

  "opacity": {
    "opacity-50": {
      "$value": 0.5, "$type": "number",
      "$description": "50% — Disabled state outer-container opacity (carries Switch + Input convention).",
      "$extensions": { "tailwind": "opacity-50", "figma": { "name": "opacity/opacity-50" } }
    },
    "opacity-60": {
      "$value": 0.6, "$type": "number",
      "$description": "60% — Checkbox Pressed state. Applied to the BOX (not the outer container). NEW.",
      "$extensions": { "tailwind": "opacity-60", "figma": { "name": "opacity/opacity-60" }, "sourceTrace": "NEW in Checkbox PoC. Pressed-state opacity application is box-level, different from Disabled which is outer-container-level (per Switch/Input pattern)." }
    },
    "opacity-70": {
      "$value": 0.7, "$type": "number",
      "$description": "70% — usage TBD. Likely another state cue (possibly Disabled-Pressed combination or Invalid-Pressed). Source token exists; cell-application not yet walked. NEW.",
      "$extensions": { "tailwind": "opacity-70", "figma": { "name": "opacity/opacity-70" }, "sourceTrace": "NEW. $usageTbd." }
    }
  },

  "font": {
    "font-sans": { "$value": "Open Sans", "$type": "fontFamily", "$extensions": { "figma": { "name": "font/font-sans" } } }
  },

  "font-weight": {
    "medium": { "$value": 500, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/medium" } } },
    "normal": { "$value": 400, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/normal" } } }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    }
  },

  "typography": {
    "text-sm-leading-none-medium": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.medium}", "fontSize": "{text.sm.font-size}", "lineHeight": "1", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Tight medium label — Checkbox label.",
      "$extensions": { "figma": { "name": "text-sm/leading-none/medium" } }
    },
    "text-sm-leading-normal-normal": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Body normal — Checkbox description.",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/normal" } }
    }
  },

  "effect": {
    "focus-default": {
      "$value": { "color": "{color.custom.outline}", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "3px", "type": "dropShadow", "inset": false },
      "$type": "shadow",
      "$description": "Focus ring — Checkbox Focus state.",
      "$extensions": { "figma": { "name": "focus/default" } }
    }
  },

  "icon-set": {
    "lucide-icons": { "$value": true, "$type": "boolean", "$extensions": { "figma": { "name": "Lucide Icons" } } }
  }
}
