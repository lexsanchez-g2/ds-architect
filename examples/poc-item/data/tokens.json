{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "Item molecule (18672:198607) + nested ItemMedia + Button.variant=Outline" },
    "modes": ["light"],
    "$note": "30+ tokens. Heavy overlap with Button + Input + Switch bundles. NEW: line-height/leading-4 (16), alpha/50 (#ffffff80). Item COMPOSES Button.variant=Outline as Actions slot — first cross-bundle composition in PoC."
  },

  "color": {
    "base": {
      "foreground":       { "$value": "#0a0a0a", "$type": "color" },
      "muted-foreground": { "$value": "#737373", "$type": "color" },
      "muted":            { "$value": "#f5f5f5", "$type": "color", "$description": "ItemMedia bg" },
      "border":           { "$value": "#e5e5e5", "$type": "color", "$description": "ItemMedia border" },
      "primary":          { "$value": "#5a35c0", "$type": "color", "$description": "Action button (Outline variant) text + border" }
    },
    "custom": {
      "background-dark-input-30": { "$value": "#fafafa", "$type": "color", "$description": "Action button bg (Outline variant)" }
    },
    "alpha": {
      "50": { "$value": "#ffffff80", "$type": "color", "$description": "White @ 50% alpha. NEW in Item PoC.", "$extensions": { "figma": { "name": "alpha/50" }, "sourceTrace": "NEW." } }
    }
  },

  "spacing": {
    "1":   { "$value": "4px",  "$type": "dimension", "$description": "Title-description gap inside ItemContent" },
    "1-5": { "$value": "6px",  "$type": "dimension" },
    "2":   { "$value": "8px",  "$type": "dimension", "$description": "Flex container gap (media → content → actions)" },
    "2-5": { "$value": "10px", "$type": "dimension", "$description": "Item container padding-y + container gap" },
    "3":   { "$value": "12px", "$type": "dimension", "$description": "Item container padding-x" },
    "8":   { "$value": "32px", "$type": "dimension", "$description": "Action button padding (inherited from Button bundle)" }
  },

  "height": {
    "h-11": { "$value": "44px", "$type": "dimension", "$description": "Action button height (inherited from Button bundle)" }
  },

  "width": {
    "w-8": { "$value": "32px", "$type": "dimension", "$description": "ItemMedia width" }
  },

  "border-radius": {
    "rounded-sm":   { "$value": "6px",     "$type": "dimension", "$description": "ItemMedia corner" },
    "rounded-lg":   { "$value": "10px",    "$type": "dimension", "$description": "Item container corner" },
    "rounded-full": { "$value": "9999px",  "$type": "dimension", "$description": "Action button (inherited from Button bundle pill convention)" }
  },

  "border-width": { "border": { "$value": "1px", "$type": "dimension" } },
  "opacity":      { "opacity-100": { "$value": 1, "$type": "number" } },

  "line-height": {
    "leading-4": { "$value": "16px", "$type": "dimension", "$description": "16px line-height for Item title (NOT the same as text-sm-line-height which is 20). Tighter than default. NEW in Item PoC.", "$extensions": { "tailwind": "leading-4", "figma": { "name": "line-height/leading-4" }, "sourceTrace": "NEW." } }
  },

  "font": { "font-sans": { "$value": "Open Sans", "$type": "fontFamily" } },
  "font-weight": {
    "medium":   { "$value": 500, "$type": "fontWeight" },
    "normal":   { "$value": 400, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" }
  },

  "text": {
    "sm": { "font-size": { "$value": "14px", "$type": "dimension" }, "line-height": { "$value": "20px", "$type": "dimension" } },
    "lg": { "font-size": { "$value": "18px", "$type": "dimension" }, "line-height": { "$value": "28px", "$type": "dimension" } },
    "xs": { "font-size": { "$value": "12px", "$type": "dimension" }, "line-height": { "$value": "16px", "$type": "dimension" } }
  },

  "typography": {
    "text-sm-leading-normal-normal": { "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" }, "$type": "typography", "$description": "Item description" },
    "text-lg-leading-normal-semibold": { "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.semibold}", "fontSize": "{text.lg.font-size}", "lineHeight": "{text.lg.line-height}", "letterSpacing": "0px" }, "$type": "typography", "$description": "Action button text (inherited from Button bundle)" },
    "text-xs-leading-normal-normal": { "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.xs.font-size}", "lineHeight": "{text.xs.line-height}", "letterSpacing": "0px" }, "$type": "typography" }
  },

  "icon-set": { "lucide-icons": { "$value": true, "$type": "boolean" } }
}
