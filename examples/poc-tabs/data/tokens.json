{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "Tabs (21133:27311) + TabsTrigger children" },
    "modes": ["light"],
    "$shadowDecompositionNote": "First Apollo v2 bundle with DECOMPOSED shadow primitives. shadow/sm/1/* + shadow/sm/2/* are atomic tokens; shadow/sm composite references them. W3C composite-token pattern, validates BUNDLE_SPEC §4.3 'shadow' type."
  },

  "color": {
    "base": {
      "primary":            { "$value": "#5a35c0", "$type": "color", "$description": "Badge fill on active+inactive TabsTrigger.", "$extensions": { "figma": { "name": "base/primary" } } },
      "primary-foreground": { "$value": "#ffffff", "$type": "color", "$description": "Badge text color.", "$extensions": { "figma": { "name": "base/primary-foreground" } } },
      "foreground":         { "$value": "#0a0a0a", "$type": "color", "$description": "Active TabsTrigger text.", "$extensions": { "figma": { "name": "base/foreground" } } },
      "muted-foreground":   { "$value": "#737373", "$type": "color", "$description": "Inactive TabsTrigger text.", "$extensions": { "figma": { "name": "base/muted-foreground" } } },
      "muted":              { "$value": "#f5f5f5", "$type": "color", "$description": "Tabs container fill (pill background).", "$extensions": { "figma": { "name": "base/muted" } } }
    },
    "custom": {
      "background-dark-input-30": { "$value": "#fafafa", "$type": "color", "$description": "Active TabsTrigger fill (raised-tab background).", "$extensions": { "figma": { "name": "custom/background dark:input\\30" } } },
      "dark-input":               { "$value": "#ffffff00", "$type": "color", "$description": "Active TabsTrigger transparent border — preserves layout space.", "$extensions": { "intent": "transparent-border", "figma": { "name": "custom/dark:input" }, "sourceTrace": "NEW in Tabs PoC." } }
    },
    "tailwind": {
      "base": {
        "transparent": { "$value": "#ffffff00", "$type": "color", "$extensions": { "figma": { "name": "tailwind colors/base/transparent" } } }
      }
    }
  },

  "spacing": {
    "1":   { "$value": "4px",  "$type": "dimension", "$extensions": { "figma": { "name": "spacing/1" } } },
    "1-5": { "$value": "6px",  "$type": "dimension", "$extensions": { "figma": { "name": "spacing/1-5" } } }
  },

  "height": {
    "h-8": { "$value": "32px", "$type": "dimension", "$description": "Tabs container height — pill toggle height. NEW in Tabs PoC.", "$extensions": { "figma": { "name": "height/h-8" }, "sourceTrace": "NEW." } }
  },

  "border-radius": {
    "rounded-md": { "$value": "8px",  "$type": "dimension", "$description": "TabsTrigger button radius.",      "$extensions": { "figma": { "name": "border-radius/rounded-md" } } },
    "rounded-lg": { "$value": "10px", "$type": "dimension", "$description": "Tabs container radius.",          "$extensions": { "figma": { "name": "border-radius/rounded-lg" } } },
    "rounded-full": { "$value": "9999px", "$type": "dimension", "$description": "Badge pill radius.",          "$extensions": { "figma": { "name": "border-radius/rounded-full" } } }
  },

  "border-width": {
    "border":   { "$value": "1px", "$type": "dimension", "$extensions": { "figma": { "name": "border-width/border" } } },
    "border-2": { "$value": "2px", "$type": "dimension", "$extensions": { "figma": { "name": "border-width/border-2" } } }
  },

  "font": {
    "font-sans": { "$value": "Open Sans", "$type": "fontFamily", "$extensions": { "figma": { "name": "font/font-sans" } } }
  },

  "font-weight": {
    "medium": { "$value": 500, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/medium" } } }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    },
    "xs": {
      "font-size":   { "$value": "12px", "$type": "dimension", "$extensions": { "figma": { "name": "text/xs/font-size" } } },
      "line-height": { "$value": "16px", "$type": "dimension", "$extensions": { "figma": { "name": "text/xs/line-height" } } }
    }
  },

  "typography": {
    "text-sm-leading-normal-medium": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.medium}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "TabsTrigger tab text (medium weight, both active + inactive).",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/medium" } }
    }
  },

  "shadow": {
    "$comment": "Decomposed shadow primitives + composite. Apollo v2 declares the 2 layers' atomic parts as separate tokens, then composes them via the shadow/sm effect.",
    "sm": {
      "1": {
        "offset-x":      { "$value": "0px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/1/offset-x" }, "sourceTrace": "NEW (decomposed primitive)." } },
        "offset-y":      { "$value": "1px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/1/offset-y" }, "sourceTrace": "NEW." } },
        "blur-radius":   { "$value": "3px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/1/blur-radius" }, "sourceTrace": "NEW." } },
        "spread-radius": { "$value": "0px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/1/spread-radius" }, "sourceTrace": "NEW." } },
        "color":         { "$value": "#0000001a", "$type": "color",    "$description": "Black @ 10% alpha — outer shadow layer color.", "$extensions": { "figma": { "name": "shadow/sm/1/color" }, "sourceTrace": "NEW." } }
      },
      "2": {
        "offset-x":      { "$value": "0px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/2/offset-x" } } },
        "offset-y":      { "$value": "1px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/2/offset-y" } } },
        "blur-radius":   { "$value": "2px",     "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/2/blur-radius" } } },
        "spread-radius": { "$value": "-1px",    "$type": "dimension", "$extensions": { "figma": { "name": "shadow/sm/2/spread-radius" } } },
        "color":         { "$value": "#0000001a", "$type": "color",    "$description": "Inner shadow layer color — same alpha." }
      }
    }
  },

  "effect": {
    "shadow-sm": {
      "$value": [
        {
          "color":   "{shadow.sm.1.color}",
          "offsetX": "{shadow.sm.1.offset-x}",
          "offsetY": "{shadow.sm.1.offset-y}",
          "blur":    "{shadow.sm.1.blur-radius}",
          "spread":  "{shadow.sm.1.spread-radius}",
          "type":    "dropShadow", "inset": false
        },
        {
          "color":   "{shadow.sm.2.color}",
          "offsetX": "{shadow.sm.2.offset-x}",
          "offsetY": "{shadow.sm.2.offset-y}",
          "blur":    "{shadow.sm.2.blur-radius}",
          "spread":  "{shadow.sm.2.spread-radius}",
          "type":    "dropShadow", "inset": false
        }
      ],
      "$type": "shadow",
      "$description": "2-layer composite drop-shadow — small elevation. Active TabsTrigger uses this. NEW in Tabs PoC. First component to use shadow.* token namespace; prior Button/Switch focus rings used focus/* effect tokens with inline atomic values.",
      "$extensions": { "intent": "elevation-sm", "shadcn": "shadow-sm", "tailwind": "shadow-sm", "css": "box-shadow: 0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)", "figma": { "name": "shadow/sm" } }
    }
  },

  "icon-set": {
    "lucide-icons": { "$value": true, "$type": "boolean", "$extensions": { "figma": { "name": "Lucide Icons" } } }
  }
}
