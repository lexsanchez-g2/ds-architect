{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": { "fileKey": "3401ZFUHoboOwA6GGjAEsq", "scope": "Avatar (node 17100:29935)" },
    "modes": ["light"],
    "overlapWithPriorBundles": {
      "uniqueToAvatar": 6,
      "$comment": "17 tokens used. 6 NEW vs prior atom bundles: width/w-5 (20), width/w-10 (40), width/w-12 (48) for the size containers; text/xs/font-size (12), text/xs/line-height (16), text-xs/leading-normal/normal compound — Avatar is the FIRST atom to use the xs text scale (Button/Switch/Input/Checkbox all stayed at sm). Plus 11 shared from prior bundles."
    }
  },

  "color": {
    "base": {
      "muted":            { "$value": "#f5f5f5", "$type": "color", "$description": "Avatar container fill (gray neutral). All Avatar Types use this as the base.", "$extensions": { "shadcn": "muted", "figma": { "name": "base/muted" } } },
      "muted-foreground": { "$value": "#737373", "$type": "color", "$description": "Avatar Fallback-Type initials text color.", "$extensions": { "figma": { "name": "base/muted-foreground" } } }
    }
  },

  "border-radius": {
    "rounded-full": { "$value": "9999px", "$type": "dimension", "$description": "Avatar is universally circular.", "$extensions": { "figma": { "name": "border-radius/rounded-full" } } }
  },

  "width": {
    "w-5":  { "$value": "20px", "$type": "dimension", "$description": "size=xs Avatar.",     "$extensions": { "tailwind": "w-5",  "figma": { "name": "width/w-5" },  "sourceTrace": "NEW in Avatar PoC." } },
    "w-6":  { "$value": "24px", "$type": "dimension", "$description": "size=sm Avatar.",     "$extensions": { "tailwind": "w-6",  "figma": { "name": "width/w-6" } } },
    "w-8":  { "$value": "32px", "$type": "dimension", "$description": "size=default Avatar.","$extensions": { "tailwind": "w-8",  "figma": { "name": "width/w-8" } } },
    "w-10": { "$value": "40px", "$type": "dimension", "$description": "size=lg Avatar.",     "$extensions": { "tailwind": "w-10", "figma": { "name": "width/w-10" }, "sourceTrace": "NEW in Avatar PoC." } },
    "w-12": { "$value": "48px", "$type": "dimension", "$description": "size=xl Avatar.",     "$extensions": { "tailwind": "w-12", "figma": { "name": "width/w-12" }, "sourceTrace": "NEW in Avatar PoC." } }
  },

  "font": {
    "font-sans": { "$value": "Open Sans", "$type": "fontFamily", "$extensions": { "figma": { "name": "font/font-sans" } } }
  },

  "font-weight": {
    "normal": { "$value": 400, "$type": "fontWeight", "$extensions": { "figma": { "name": "font-weight/normal" } } }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension", "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    },
    "xs": {
      "font-size":   { "$value": "12px", "$type": "dimension", "$description": "xs text scale — Avatar Fallback at sm/xs sizes (likely).", "$extensions": { "tailwind": "text-xs", "figma": { "name": "text/xs/font-size" }, "sourceTrace": "NEW in Avatar PoC. First atom to use xs text scale." } },
      "line-height": { "$value": "16px", "$type": "dimension", "$extensions": { "figma": { "name": "text/xs/line-height" }, "sourceTrace": "NEW in Avatar PoC." } }
    }
  },

  "typography": {
    "text-sm-leading-normal-normal": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.sm.font-size}", "lineHeight": "{text.sm.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Body sm — Avatar Fallback initials (default + lg sizes).",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/normal" } }
    },
    "text-xs-leading-normal-normal": {
      "$value": { "fontFamily": "{font.font-sans}", "fontWeight": "{font-weight.normal}", "fontSize": "{text.xs.font-size}", "lineHeight": "{text.xs.line-height}", "letterSpacing": "0px" },
      "$type": "typography",
      "$description": "Body xs — Avatar Fallback initials at small sizes (sm/xs).",
      "$extensions": { "figma": { "name": "text-xs/leading-normal/normal" }, "sourceTrace": "NEW in Avatar PoC." }
    }
  },

  "icon-set": {
    "lucide-icons": { "$value": true, "$type": "boolean", "$extensions": { "figma": { "name": "Lucide Icons" } } }
  }
}
